<span id="cb10-554"><a href="#cb10-554" aria-hidden="true" tabindex="-1"></a><span class="co"># Count top-rated movies by country</span></span>
<span id="cb10-555"><a href="#cb10-555" aria-hidden="true" tabindex="-1"></a>top_rated_country_counts <span class="op">=</span> top_rated_movies[<span class="st">&#39;primary_country&#39;</span>].value_counts().nlargest(<span class="dv">10</span>).reset_index()</span>
