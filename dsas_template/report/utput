<span id="cb1-8"><a href="#cb1-8" aria-hidden="true" tabindex="-1"></a>data_q1[<span class="st">&#39;decade&#39;</span>] <span class="op">=</span> (data_q1[<span class="st">&#39;release_date&#39;</span>].dt.year <span class="op">//</span> <span class="dv">10</span>) <span class="op">*</span> <span class="dv">10</span></span>
<span id="cb1-9"><a href="#cb1-9" aria-hidden="true" tabindex="-1"></a>data_q1 <span class="op">=</span> data_q1[data_q1[<span class="st">&#39;decade&#39;</span>] <span class="op">&gt;=</span> <span class="dv">1990</span>] <span class="co"># Filter for the correct time period</span></span>
<span id="cb1-10"><a href="#cb1-10" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-11"><a href="#cb1-11" aria-hidden="true" tabindex="-1"></a><span class="co"># Safely evaluate the &#39;genres&#39; string into a list</span></span>
<span id="cb1-12"><a href="#cb1-12" aria-hidden="true" tabindex="-1"></a>data_q1[<span class="st">&#39;genres_list&#39;</span>] <span class="op">=</span> data_q1[<span class="st">&#39;genres&#39;</span>].<span class="bu">apply</span>(<span class="kw">lambda</span> x: ast.literal_eval(x) <span class="cf">if</span> <span class="bu">isinstance</span>(x, <span class="bu">str</span>) <span class="kw">and</span> x.startswith(<span class="st">&#39;[&#39;</span>) <span class="cf">else</span> [])</span>
<span id="cb1-13"><a href="#cb1-13" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-14"><a href="#cb1-14" aria-hidden="true" tabindex="-1"></a><span class="co"># Calculate weight for each genre (1 / number of genres)</span></span>
<span id="cb1-15"><a href="#cb1-15" aria-hidden="true" tabindex="-1"></a>data_q1[<span class="st">&#39;genre_weight&#39;</span>] <span class="op">=</span> data_q1[<span class="st">&#39;genres_list&#39;</span>].<span class="bu">apply</span>(<span class="kw">lambda</span> x: <span class="dv">1</span><span class="op">/</span><span class="bu">len</span>(x) <span class="cf">if</span> <span class="bu">len</span>(x) <span class="op">&gt;</span> <span class="dv">0</span> <span class="cf">else</span> <span class="dv">0</span>)</span>
<span id="cb1-16"><a href="#cb1-16" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-17"><a href="#cb1-17" aria-hidden="true" tabindex="-1"></a><span class="co"># Explode the DataFrame to have one row per genre for each movie</span></span>
<span id="cb1-18"><a href="#cb1-18" aria-hidden="true" tabindex="-1"></a>genre_data <span class="op">=</span> data_q1.explode(<span class="st">&#39;genres_list&#39;</span>)</span>
<span id="cb1-19"><a href="#cb1-19" aria-hidden="true" tabindex="-1"></a>genre_data <span class="op">=</span> genre_data.rename(columns<span class="op">=</span>{<span class="st">&#39;genres_list&#39;</span>: <span class="st">&#39;genre&#39;</span>})</span>
<span id="cb1-20"><a href="#cb1-20" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-21"><a href="#cb1-21" aria-hidden="true" tabindex="-1"></a><span class="co"># Calculate total movies per decade (for proportion calculation)</span></span>
<span id="cb1-22"><a href="#cb1-22" aria-hidden="true" tabindex="-1"></a>decade_totals <span class="op">=</span> data_q1.groupby(<span class="st">&#39;decade&#39;</span>).size().reset_index(name<span class="op">=</span><span class="st">&#39;total_count&#39;</span>)</span>
