<div id="cb5" class="sourceCode cell-code">
<pre class="sourceCode python code-with-copy"><code class="sourceCode python"><span id="cb5-1"><a href="#cb5-1" aria-hidden="true" tabindex="-1"></a><span class="co"># Calculate average duration per year</span></span>
<span id="cb5-2"><a href="#cb5-2" aria-hidden="true" tabindex="-1"></a>avg_duration_per_year <span class="op">=</span> data.groupby(data[<span class="st">&#39;release_date&#39;</span>].dt.year)[<span class="st">&#39;duration_minutes&#39;</span>].mean().reset_index()</span>
<span id="cb5-3"><a href="#cb5-3" aria-hidden="true" tabindex="-1"></a>avg_duration_per_year.columns <span class="op">=</span> [<span class="st">&#39;year&#39;</span>, <span class="st">&#39;avg_duration&#39;</span>]</span>
