<span id="cb6-30"><a href="#cb6-30" aria-hidden="true" tabindex="-1"></a>sns.barplot(data<span class="op">=</span>top_countries_per_decade, x<span class="op">=</span><span class="st">&#39;decade&#39;</span>, y<span class="op">=</span><span class="st">&#39;count&#39;</span>, hue<span class="op">=</span><span class="st">&#39;primary_country&#39;</span>, ax<span class="op">=</span>ax, palette<span class="op">=</span><span class="st">&#39;viridis&#39;</span>)</span>
