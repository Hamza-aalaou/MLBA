<span id="cb1-24"><a href="#cb1-24" aria-hidden="true" tabindex="-1"></a><span class="co"># Calculate weighted count of each genre per decade</span></span>
<span id="cb1-25"><a href="#cb1-25" aria-hidden="true" tabindex="-1"></a>genre_counts <span class="op">=</span> genre_data.groupby([<span class="st">&#39;decade&#39;</span>, <span class="st">&#39;genre&#39;</span>])[<span class="st">&#39;genre_weight&#39;</span>].<span class="bu">sum</span>().reset_index(name<span class="op">=</span><span class="st">&#39;count&#39;</span>)</span>
<span id="cb1-26"><a href="#cb1-26" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-27"><a href="#cb1-27" aria-hidden="true" tabindex="-1"></a><span class="co"># Merge to get total counts and calculate proportion</span></span>
<span id="cb1-28"><a href="#cb1-28" aria-hidden="true" tabindex="-1"></a>genre_counts <span class="op">=</span> pd.merge(genre_counts, decade_totals, on<span class="op">=</span><span class="st">&#39;decade&#39;</span>)</span>
<span id="cb1-29"><a href="#cb1-29" aria-hidden="true" tabindex="-1"></a>genre_counts[<span class="st">&#39;proportion&#39;</span>] <span class="op">=</span> genre_counts[<span class="st">&#39;count&#39;</span>] <span class="op">/</span> genre_counts[<span class="st">&#39;total_count&#39;</span>]</span>
<span id="cb1-30"><a href="#cb1-30" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-31"><a href="#cb1-31" aria-hidden="true" tabindex="-1"></a><span class="co"># Get the top 5 genres per decade based on proportion</span></span>
<span id="cb1-32"><a href="#cb1-32" aria-hidden="true" tabindex="-1"></a>top_genres_per_decade <span class="op">=</span> (</span>
<span id="cb1-33"><a href="#cb1-33" aria-hidden="true" tabindex="-1"></a>    genre_counts.groupby(<span class="st">&#39;decade&#39;</span>)</span>
<span id="cb1-34"><a href="#cb1-34" aria-hidden="true" tabindex="-1"></a>    .<span class="bu">apply</span>(<span class="kw">lambda</span> x: x.nlargest(<span class="dv">5</span>, <span class="st">&#39;proportion&#39;</span>))</span>
<span id="cb1-35"><a href="#cb1-35" aria-hidden="true" tabindex="-1"></a>    .reset_index(drop<span class="op">=</span><span class="va">True</span>)</span>
<span id="cb1-36"><a href="#cb1-36" aria-hidden="true" tabindex="-1"></a>)</span>
<span id="cb1-37"><a href="#cb1-37" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-38"><a href="#cb1-38" aria-hidden="true" tabindex="-1"></a><span class="co"># Create the plot</span></span>
<span id="cb1-39"><a href="#cb1-39" aria-hidden="true" tabindex="-1"></a>fig, ax <span class="op">=</span> plt.subplots(figsize<span class="op">=</span>(<span class="fl">8.25</span>, <span class="fl">5.25</span>))</span>
<span id="cb1-40"><a href="#cb1-40" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-41"><a href="#cb1-41" aria-hidden="true" tabindex="-1"></a>sns.barplot(data<span class="op">=</span>top_genres_per_decade, x<span class="op">=</span><span class="st">&#39;decade&#39;</span>, y<span class="op">=</span><span class="st">&#39;proportion&#39;</span>, hue<span class="op">=</span><span class="st">&#39;genre&#39;</span>, ax<span class="op">=</span>ax)</span>
<span id="cb1-42"><a href="#cb1-42" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-43"><a href="#cb1-43" aria-hidden="true" tabindex="-1"></a><span class="co"># Add film count annotations on the x-axis</span></span>
<span id="cb1-44"><a href="#cb1-44" aria-hidden="true" tabindex="-1"></a>decade_counts_dict <span class="op">=</span> decade_totals.set_index(<span class="st">&#39;decade&#39;</span>)[<span class="st">&#39;total_count&#39;</span>].to_dict()</span>
<span id="cb1-45"><a href="#cb1-45" aria-hidden="true" tabindex="-1"></a>x_labels <span class="op">=</span> [<span class="ss">f&quot;</span><span class="sc">{</span><span class="bu">int</span>(decade)<span class="sc">}</span><span class="ss">s</span><span class="ch">\n</span><span class="ss">(n=</span><span class="sc">{</span>decade_counts_dict<span class="sc">.</span>get(decade, <span class="dv">0</span>)<span class="sc">:,}</span><span class="ss">)&quot;</span> </span>
<span id="cb1-46"><a href="#cb1-46" aria-hidden="true" tabindex="-1"></a>            <span class="cf">for</span> decade <span class="kw">in</span> <span class="bu">sorted</span>(decade_totals[<span class="st">&#39;decade&#39;</span>].unique())]</span>
<span id="cb1-47"><a href="#cb1-47" aria-hidden="true" tabindex="-1"></a>ax.set_xticklabels(x_labels)</span>
<span id="cb1-48"><a href="#cb1-48" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb1-49"><a href="#cb1-49" aria-hidden="true" tabindex="-1"></a><span class="co"># Customize plot</span></span>
<span id="cb1-50"><a href="#cb1-50" aria-hidden="true" tabindex="-1"></a>ax.set_title(<span class="st">&quot;Proportion of Dominant Film Genres by Decade&quot;</span>, </span>
