<span id="cb5-8"><a href="#cb5-8" aria-hidden="true" tabindex="-1"></a>sns.lineplot(data<span class="op">=</span>avg_duration_per_year, x<span class="op">=</span><span class="st">&#39;year&#39;</span>, y<span class="op">=</span><span class="st">&#39;avg_duration&#39;</span>, ax<span class="op">=</span>ax, marker<span class="op">=</span><span class="st">&#39;.&#39;</span>, color<span class="op">=</span><span class="st">&#39;darkgreen&#39;</span>)</span>
<span id="cb5-9"><a href="#cb5-9" aria-hidden="true" tabindex="-1"></a></span>
<span id="cb5-10"><a href="#cb5-10" aria-hidden="true" tabindex="-1"></a><span class="co"># Add a trend line to show the overall increase</span></span>
<span id="cb5-11"><a href="#cb5-11" aria-hidden="true" tabindex="-1"></a>sns.regplot(data<span class="op">=</span>avg_duration_per_year, x<span class="op">=</span><span class="st">&#39;year&#39;</span>, y<span class="op">=</span><span class="st">&#39;avg_duration&#39;</span>, ax<span class="op">=</span>ax, scatter<span class="op">=</span><span class="va">False</span>, color<span class="op">=</span><span class="st">&#39;red&#39;</span>, line_kws<span class="op">=</span>{<span class="st">&#39;linestyle&#39;</span>:<span class="st">&#39;--&#39;</span>})</span>
