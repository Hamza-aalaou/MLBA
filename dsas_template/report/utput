<span id="cb4-22"><a href="#cb4-22" aria-hidden="true" tabindex="-1"></a>ax.plot([<span class="fl">1e4</span>, max_val], [<span class="fl">1e4</span>, max_val], <span class="st">&#39;k--&#39;</span>, linewidth<span class="op">=</span><span class="fl">1.5</span>, alpha<span class="op">=</span><span class="fl">0.8</span>, label<span class="op">=</span><span class="st">&#39;Break-even (Gross = Budget)&#39;</span>)</span>
